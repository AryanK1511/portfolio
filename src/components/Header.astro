---
import Link from '@/components/Link.astro'
import MobileMenu from '@/components/ui/mobile-menu'
import { NAV_LINKS, SITE } from '@/consts'
import { Image } from 'astro:assets'
import logo from '../../public/static/logo.svg'
---

<header class="site-header" data-site-header transition:persist>
  <div
    class="site-header__bar mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-3"
  >
    <Link href="/" class="flex shrink-0 items-center justify-center gap-3">
      <Image src={logo} alt="Logo" class="size-5 sm:size-6" />
      <span class="hidden h-full text-lg font-medium min-[300px]:block"
        >{SITE.title}</span
      >
    </Link>
    <div class="flex items-center sm:gap-4">
      <nav class="hidden items-center gap-4 text-sm sm:flex sm:gap-6">
        {
          NAV_LINKS.map((item) => (
            <Link
              href={item.href}
              class="text-foreground/60 hover:text-foreground/80 capitalize transition-colors"
            >
              {item.label}
            </Link>
          ))
        }
      </nav>
      <MobileMenu client:load transition:persist />
    </div>
  </div>
</header>

<script>
  const updateSiteHeader = () => {
    const header = document.querySelector<HTMLElement>('[data-site-header]')

    if (!header) {
      return
    }

    header.toggleAttribute('data-scrolled', window.scrollY > 12)
  }

  const setupSiteHeader = () => {
    updateSiteHeader()
    window.removeEventListener('scroll', updateSiteHeader)
    window.addEventListener('scroll', updateSiteHeader, { passive: true })
  }

  setupSiteHeader()
  document.addEventListener('astro:page-load', setupSiteHeader)
</script>

<style>
  .site-header {
    pointer-events: none;
    padding: 0.5rem 0.75rem 0;
  }

  .site-header__bar {
    pointer-events: auto;
    width: 100%;
    border: 1px solid transparent;
    border-radius: 0.5rem;
    background: transparent;
    box-shadow: 0 0 0 transparent;
    transform: translateY(0);
    transition:
      padding 420ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 420ms ease,
      background-color 420ms ease,
      box-shadow 420ms ease,
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-header[data-scrolled] .site-header__bar {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    border-color: var(--border);
    background: color-mix(in oklch, var(--background) 78%, transparent);
    box-shadow: 0 18px 40px oklch(0 0 0 / 25%);
    backdrop-filter: blur(16px);
    transform: translateY(0.25rem);
  }
</style>
